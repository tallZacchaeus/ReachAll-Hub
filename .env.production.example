##############################################################################
# ReachAll Hub — Production Environment Template (Hostinger VPS or equivalent)
#
# Copy this file to /var/www/reachall-hub/.env on the production server and
# fill in every value. NEVER `cp .env .env.production` from a dev machine —
# dev defaults (QUEUE_CONNECTION=sync, CACHE_STORE=file, SESSION_DRIVER=file,
# BROADCAST_CONNECTION=log, MAIL_MAILER=log) silently break payroll
# notifications, finance jobs, chat broadcasting, and audit cache busting in
# production.
#
# Lines marked [REQUIRED] must be filled in before the application starts.
# Lines marked [REQUIRED if X] are conditional on a feature you've enabled.
##############################################################################

# ── Application ──────────────────────────────────────────────────────────────
APP_NAME="ReachAll Hub"
APP_ENV=production                          # [REQUIRED]
APP_KEY=                                    # [REQUIRED] run: php artisan key:generate
APP_DEBUG=false                             # [REQUIRED] MUST be false in production
APP_URL=https://yourdomain.com              # [REQUIRED]
APP_TIMEZONE=Africa/Lagos                   # WAT (UTC+1) — affects SLA deadlines and report timestamps

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

# ── Security ─────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=daily                             # [REQUIRED]
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error                             # [REQUIRED] avoid 'debug' in production
LOG_DAILY_DAYS=30

# ── Database ─────────────────────────────────────────────────────────────────
DB_CONNECTION=mysql                         # [REQUIRED]
DB_HOST=127.0.0.1                           # [REQUIRED]
DB_PORT=3306                                # [REQUIRED]
DB_DATABASE=reachall_hub                    # [REQUIRED]
DB_USERNAME=reachall_user                   # [REQUIRED]
DB_PASSWORD=                                # [REQUIRED] strong, unique
DB_CHARSET=utf8mb4                          # [REQUIRED] emoji + international names
DB_COLLATION=utf8mb4_unicode_ci             # [REQUIRED]

# ── Session ──────────────────────────────────────────────────────────────────
SESSION_DRIVER=database                     # [REQUIRED] NOT file/array on multi-server
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=yourdomain.com               # [REQUIRED]
SESSION_SECURE_COOKIE=true                  # [REQUIRED] HTTPS only
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax
SESSION_EXPIRE_ON_CLOSE=false

# ── Queue ─────────────────────────────────────────────────────────────────────
# [REQUIRED] "database" or "redis" — NEVER "sync" in production. Without a
# worker, PostLedgerEntry blocks the request thread and email notifications
# silently fail under load.
# Run the worker via systemd or Supervisor:
#   php artisan queue:work --queue=default --tries=3 --timeout=60
QUEUE_CONNECTION=database                   # [REQUIRED]

# ── Cache ─────────────────────────────────────────────────────────────────────
# [REQUIRED] "database" or "redis" — NOT "file"/"array". The PermissionService
# RBAC cache, finance dashboard 5-min cache, and period-reopen second-token
# guard all rely on persistent cross-request storage.
CACHE_STORE=database                        # [REQUIRED]

# ── Broadcasting (chat, finance approvals) ───────────────────────────────────
# [REQUIRED] "pusher" (or compatible) — NOT "log". Without it, the React UI
# never receives realtime chat / requisition / approval events.
BROADCAST_CONNECTION=pusher                 # [REQUIRED]
PUSHER_APP_ID=                              # [REQUIRED if pusher]
PUSHER_APP_KEY=                             # [REQUIRED if pusher]
PUSHER_APP_SECRET=                          # [REQUIRED if pusher] — NEVER commit
PUSHER_APP_CLUSTER=mt1
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https

# ── File Storage ─────────────────────────────────────────────────────────────
# Persistent, backed-up storage required. "s3" is recommended on Hostinger VPS
# so receipts and HR documents survive a server replacement; "local" is
# acceptable on a single VPS with daily off-host backups (see deploy
# checklist § 10 Backups).
FILESYSTEM_DISK=local                       # [REQUIRED] "s3" recommended
FINANCE_DISK=local                          # [REQUIRED] "s3" for finance vault
HR_DISK=local                               # [REQUIRED] "s3" for HR vault
CHAT_DISK=local                             # [REQUIRED] "s3" for chat attachments (SEC-02)

# AWS S3 (only needed if any *_DISK above is "s3"):
AWS_ACCESS_KEY_ID=                          # [REQUIRED if S3]
AWS_SECRET_ACCESS_KEY=                      # [REQUIRED if S3] — NEVER commit
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=                                 # [REQUIRED if S3]
AWS_FINANCE_BUCKET=                         # optional separate private bucket
AWS_HR_BUCKET=                              # optional separate private bucket
AWS_CHAT_BUCKET=                            # optional separate private bucket
AWS_URL=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ── Mail ─────────────────────────────────────────────────────────────────────
# [REQUIRED] real SMTP/Mailgun/Postmark/SES — NOT "log". Finance approval
# notifications, period-close alerts, and budget warnings depend on delivery.
MAIL_MAILER=smtp                            # [REQUIRED]
MAIL_HOST=                                  # [REQUIRED]
MAIL_PORT=587                               # [REQUIRED] TLS=587, SSL=465
MAIL_USERNAME=                              # [REQUIRED]
MAIL_PASSWORD=                              # [REQUIRED] — NEVER commit
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=no-reply@yourdomain.com   # [REQUIRED]
MAIL_FROM_NAME="ReachAll Hub"

# ── Error Monitoring (Sentry) ─────────────────────────────────────────────────
SENTRY_LARAVEL_DSN=                         # [REQUIRED] from Sentry → Project Settings → SDK Setup
SENTRY_TRACES_SAMPLE_RATE=0.1               # 10 % performance tracing

# ── Finance Module ────────────────────────────────────────────────────────────
FINANCE_VAT_RATE=0.075                      # FIRS VAT rate (decimal). Configurable.
FINANCE_MATCH_THRESHOLD_KOBO=50000000       # ₦500K — three-way match threshold
FINANCE_PETTY_CASH_SINGLE_CAP_KOBO=1000000  # ₦10K single-transaction cap

# ── Vite (build-time only, usually unchanged) ────────────────────────────────
VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"

##############################################################################
# Post-deploy operations (see docs/audits/now-deploy-checklist for full runbook)
#
#   php artisan storage:link
#   php artisan migrate --force
#   php artisan chat:migrate-attachments --dry-run
#   php artisan chat:migrate-attachments
#   php artisan db:seed --force --class=RolesAndPermissionsSeeder
#   php artisan config:cache && php artisan route:cache && php artisan view:cache
#
# SEC-03 audit-log immutability — strip UPDATE/DELETE from the app DB user
# AFTER the migration has created audit_logs:
#   REVOKE UPDATE, DELETE ON reachall_hub.audit_logs FROM 'reachall_user'@'127.0.0.1';
#   GRANT  INSERT, SELECT      ON reachall_hub.audit_logs TO   'reachall_user'@'127.0.0.1';
##############################################################################
