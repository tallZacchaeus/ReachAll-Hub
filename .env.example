##############################################################################
# ReachAll Hub — Environment Configuration Template
# Copy to .env and fill in all values before running the app.
# NEVER commit .env to version control — this file is safe to commit.
# Lines marked [PROD REQUIRED] must be explicitly set before going live.
##############################################################################

# ── Application ──────────────────────────────────────────────────────────────
APP_NAME="ReachAll Hub"
APP_ENV=local               # [PROD REQUIRED] set to "production" on the server
APP_KEY=                    # [PROD REQUIRED] run: php artisan key:generate
APP_DEBUG=false             # [PROD REQUIRED] MUST be false in production
APP_URL=http://localhost     # [PROD REQUIRED] full URL e.g. https://reachall.example.com
APP_TIMEZONE=Africa/Lagos   # WAT (UTC+1) — affects SLA deadlines and report timestamps

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database
# CAT11-05: Maintenance mode with bypass secret (finance team can still access during maintenance):
#   Enable:  php artisan down --secret=finance-bypass-token --render="errors.503"
#   Bypass:  visit https://yourapp.com/finance-bypass-token  (sets a cookie)
#   Disable: php artisan up

# PHP_CLI_SERVER_WORKERS=4

# ── Security ─────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12            # increase to 14 for extra security on modern hardware

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=single            # [PROD REQUIRED] use "daily" with LOG_DAILY_DAYS=30
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug             # [PROD REQUIRED] use "error" in production
# LOG_DAILY_DAYS=30

# ── Database ─────────────────────────────────────────────────────────────────
# Dev default (SQLite):
DB_CONNECTION=sqlite
# DB_DATABASE=/absolute/path/to/database.sqlite

# Production (MySQL — uncomment and fill):
# DB_CONNECTION=mysql        # [PROD REQUIRED]
# DB_HOST=127.0.0.1          # [PROD REQUIRED]
# DB_PORT=3306               # [PROD REQUIRED]
# DB_DATABASE=reachall_hub   # [PROD REQUIRED]
# DB_USERNAME=reachall_user  # [PROD REQUIRED]
# DB_PASSWORD=               # [PROD REQUIRED]
# DB_CHARSET=utf8mb4         # [PROD REQUIRED] emoji + international vendor names

# ── Session ──────────────────────────────────────────────────────────────────
# [PROD REQUIRED] "database" or "redis" — NOT "file" on multi-server deployments
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true        # Default true (config/session.php default); set false only if local HTTP dev requires it
SESSION_PATH=/
SESSION_DOMAIN=yourdomain.com  # [PROD REQUIRED] set to your domain (no leading dot unless subdomain sharing needed)
SESSION_SECURE_COOKIE=true  # [PROD REQUIRED] true in production (HTTPS); auto-false in local dev via app()->isProduction()
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax
SESSION_EXPIRE_ON_CLOSE=false

# ── Finance Module ────────────────────────────────────────────────────────────
FINANCE_VAT_RATE=0.075          # CAT10-03: FIRS VAT rate (decimal). Update without redeployment.
FINANCE_MATCH_THRESHOLD_KOBO=50000000  # ₦500K — three-way match required above this
FINANCE_PETTY_CASH_SINGLE_CAP_KOBO=1000000  # ₦10K single-transaction cap

# ── Error Monitoring (Sentry) ─────────────────────────────────────────────────
# [PROD REQUIRED] Get your DSN from https://sentry.io → Project Settings → SDK Setup
# Leave blank in local development to disable Sentry reporting.
SENTRY_LARAVEL_DSN=            # [PROD REQUIRED] e.g. https://abc123@o0.ingest.sentry.io/0
SENTRY_TRACES_SAMPLE_RATE=0.1  # 10 % performance tracing in production

# ── Broadcasting (Pusher) ─────────────────────────────────────────────────────
BROADCAST_CONNECTION=log    # [PROD REQUIRED] change to "pusher" for real-time notifications
PUSHER_APP_ID=              # [PROD REQUIRED if pusher]
PUSHER_APP_KEY=             # [PROD REQUIRED if pusher]
PUSHER_APP_SECRET=          # [PROD REQUIRED if pusher] — NEVER commit the real value
PUSHER_APP_CLUSTER=mt1
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https

# ── File Storage ─────────────────────────────────────────────────────────────
# [PROD REQUIRED] change to "s3" — local disk is lost if the server is replaced
# Finance receipts and supporting documents require persistent, backed-up storage.
FILESYSTEM_DISK=local

# AWS S3 (if FILESYSTEM_DISK=s3):
AWS_ACCESS_KEY_ID=          # [PROD REQUIRED if S3]
AWS_SECRET_ACCESS_KEY=      # [PROD REQUIRED if S3] — NEVER commit
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=                 # [PROD REQUIRED if S3]
AWS_USE_PATH_STYLE_ENDPOINT=false

# ── Queue ─────────────────────────────────────────────────────────────────────
# [PROD REQUIRED] "database" or "redis" — NEVER "sync" in production.
# "sync" processes jobs inline; PostLedgerEntry and email notifications will block
# the HTTP request and may silently fail under load.
# Run the worker: php artisan queue:work --queue=default --tries=3 --timeout=60
QUEUE_CONNECTION=database

# ── Cache ─────────────────────────────────────────────────────────────────────
# [PROD REQUIRED] "redis" or "database" — NOT "array".
# Finance dashboard widgets cache for 300 s; "array" caches nothing across requests.
CACHE_STORE=database
# CACHE_PREFIX=

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_CLIENT=phpredis       # requires ext-redis; use "predis" if not available
REDIS_HOST=127.0.0.1        # [PROD REQUIRED if redis]
REDIS_PASSWORD=null         # [PROD REQUIRED if redis] set a strong password
REDIS_PORT=6379

# ── Mail ─────────────────────────────────────────────────────────────────────
# [PROD REQUIRED] "smtp", "mailgun", "postmark", or "ses" — NOT "log".
# Finance notifications (approval alerts, period close, budget blocks) depend on delivery.
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1         # [PROD REQUIRED]
MAIL_PORT=2525              # [PROD REQUIRED] typically 587 (TLS) or 465 (SSL)
MAIL_USERNAME=null          # [PROD REQUIRED]
MAIL_PASSWORD=null          # [PROD REQUIRED] — NEVER commit the real value
MAIL_FROM_ADDRESS="hello@example.com"  # [PROD REQUIRED]
MAIL_FROM_NAME="${APP_NAME}"

# ── Memcached (only if CACHE_STORE=memcached) ─────────────────────────────────
MEMCACHED_HOST=127.0.0.1

# ── Vite / Frontend ──────────────────────────────────────────────────────────
VITE_APP_NAME="${APP_NAME}"
# VITE_DEV_SERVER_HOST=     # only needed when Vite runs on a non-localhost interface
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"

##############################################################################
# Finance Module — production checklist (run these once after deployment)
#
# 1. php artisan storage:link
#    Creates public/storage symlink for uploaded receipts and documents.
#
# 2. php artisan migrate --force
#    Runs all pending migrations including period-close dual-auth tables.
#
# 3. Create the current FinancialPeriod (if not seeded):
#    php artisan tinker --execute="
#      App\Models\Finance\FinancialPeriod::create([
#        'year'=>now()->year,'month'=>now()->month,
#        'status'=>'open','opened_at'=>now()->startOfMonth()]);
#    "
#
# 4. Start the queue worker (Supervisor / systemd):
#    php artisan queue:work --queue=default --tries=3 --timeout=60
#    PostLedgerEntry will NOT run without a live worker.
#
# 5. Visit /finance/go-live as superadmin and confirm all 13 checks pass.
##############################################################################
